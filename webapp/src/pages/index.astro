---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inicio">
  <!-- Hero Section — DESIGN_SYSTEM.md Sección 6.2 -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- BG: gradient-overlay sobre #000949 -->
    <div class="absolute inset-0 gradient-primary"></div>
    <div class="absolute inset-0 gradient-overlay"></div>
    <!-- Dot pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.4) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <!-- Glow effects -->
    <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-ijam-accent/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-ijam-primary-deep/30 rounded-full blur-[100px]"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center animate-fade-in">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-ijam-accent/10 border border-ijam-accent/25 rounded-full px-5 py-2 mb-8">
        <svg class="w-4 h-4 text-ijam-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
        <span class="text-ijam-accent text-xs font-bold tracking-widest uppercase">Instituto John A. Mackay</span>
      </div>

      <!-- Title -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
        Biblioteca Virtual
        <span class="block text-ijam-accent mt-2">IJAM</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-white/80 max-w-2xl mx-auto mb-10 font-light leading-relaxed">
        Accede a recursos educativos del instituto. Una colección meticulosamente curada disponible para préstamo o lectura en línea.
      </p>

      <!-- Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-16">
        <a href="/catalogo" class="px-8 py-3.5 bg-ijam-accent text-ijam-primary font-bold text-sm rounded-[var(--radius-md)] shadow-md shadow-ijam-accent/25 hover:brightness-110 hover:shadow-lg hover:shadow-ijam-accent/35 hover:-translate-y-0.5 transition-all duration-200 inline-flex items-center gap-2">
          Explorar Catálogo
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </a>
        <a href="/login" class="px-8 py-3.5 border-2 border-ijam-accent text-ijam-accent font-semibold text-sm rounded-[var(--radius-md)] hover:bg-ijam-accent/10 transition-all duration-200 inline-flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" /></svg>
          Iniciar Sesión
        </a>
      </div>

      <!-- Stats bar -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-3xl mx-auto">
        <div class="bg-white/10 border border-ijam-accent/20 rounded-xl px-4 py-5 backdrop-blur-sm">
          <p class="text-2xl sm:text-3xl font-extrabold text-white mb-1">500+</p>
          <p class="text-white/50 text-xs font-medium uppercase tracking-wider">Libros</p>
        </div>
        <div class="bg-white/10 border border-ijam-accent/20 rounded-xl px-4 py-5 backdrop-blur-sm">
          <p class="text-2xl sm:text-3xl font-extrabold text-ijam-accent mb-1">200+</p>
          <p class="text-white/50 text-xs font-medium uppercase tracking-wider">Alumnos</p>
        </div>
        <div class="bg-white/10 border border-ijam-accent/20 rounded-xl px-4 py-5 backdrop-blur-sm">
          <p class="text-2xl sm:text-3xl font-extrabold text-white mb-1">50+</p>
          <p class="text-white/50 text-xs font-medium uppercase tracking-wider">PDFs</p>
        </div>
        <div class="bg-white/10 border border-ijam-accent/20 rounded-xl px-4 py-5 backdrop-blur-sm">
          <p class="text-2xl sm:text-3xl font-extrabold text-ijam-accent mb-1">24/7</p>
          <p class="text-white/50 text-xs font-medium uppercase tracking-wider">Acceso</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
