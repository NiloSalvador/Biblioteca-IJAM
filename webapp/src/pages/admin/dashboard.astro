---
import Layout from '../../layouts/Layout.astro';
import { supabaseServer } from '../../lib/supabaseServer';

import { Book, Clock, AlertTriangle, Bookmark } from 'lucide-react';

const supabase = supabaseServer(Astro.cookies, Astro.request);

// 1. Validar Sesión y Rol de Admin
const { data: { session } } = await supabase.auth.getSession();
if (!session) {
  return Astro.redirect('/login');
}

const { data: profile } = await supabase.from('users').select('role').eq('id', session.user.id).single();
if (profile?.role !== 'ADMIN') {
  return Astro.redirect('/catalogo');
}

// 2. Traer Estadísticas y Datos
const { count: booksCount } = await supabase.from('books').select('*', { count: 'exact', head: true });
const { count: usersCount } = await supabase.from('users').select('*', { count: 'exact', head: true });

// Préstamos activos o pendientes
const { data: recentLoans } = await supabase
  .from('loans')
  .select(`
    id,
    loan_date,
    status,
    user_id,
    users ( full_name, institutional_email ),
    books ( title, type )
  `)
  .in('status', ['ACTIVE', 'RESERVED', 'OVERDUE'])
  .order('loan_date', { ascending: false })
  .limit(10);

const activeLoansCount = recentLoans?.filter(l => l.status === 'ACTIVE').length || 0;
const reservedLoansCount = recentLoans?.filter(l => l.status === 'RESERVED').length || 0;
const overdueLoansCount = recentLoans?.filter(l => l.status === 'OVERDUE').length || 0;


---

<Layout title="Dashboard Administrativo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-3">
        <span class="bg-ijam-accent/15 text-ijam-accent text-xs font-bold px-3 py-1.5 rounded-full tracking-widest uppercase border border-ijam-accent/25">
          Panel de Control
        </span>
      </div>
      <h1 class="text-3xl font-bold text-ijam-primary">Gestión de Biblioteca IJAM</h1>
      <p class="text-ijam-text-muted font-medium mt-1">Supervisa inventario, préstamos y usuarios.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      <!-- Stat Card 1: Total Libros -->
      <div class="bg-white border-y border-r border-[#E2E8F0] border-l-4 border-l-ijam-accent rounded-xl p-6 shadow-card flex items-center justify-between card-hover transition-base">
        <div>
          <p class="text-sm font-medium text-ijam-text-muted mb-1">Total Obras</p>
          <p class="text-3xl font-bold text-ijam-primary">{booksCount || 0}</p>
        </div>
        <div class="w-12 h-12 bg-ijam-accent/10 text-ijam-accent rounded-xl flex items-center justify-center">
          <Book className="w-6 h-6" />
        </div>
      </div>
      
      <!-- Stat Card 2: Préstamos Activos -->
      <div class="bg-white border-y border-r border-[#E2E8F0] border-l-4 border-l-ijam-success rounded-xl p-6 shadow-card flex items-center justify-between card-hover transition-base">
        <div>
          <p class="text-sm font-medium text-ijam-text-muted mb-1">Activos</p>
          <p class="text-3xl font-bold text-ijam-primary">{activeLoansCount}</p>
        </div>
        <div class="w-12 h-12 bg-ijam-success/10 text-ijam-success rounded-xl flex items-center justify-center">
          <Clock className="w-6 h-6" />
        </div>
      </div>

      <!-- Stat Card 3: Reservados -->
      <div class="bg-white border-y border-r border-[#E2E8F0] border-l-4 border-l-ijam-warning rounded-xl p-6 shadow-card flex items-center justify-between card-hover transition-base">
        <div>
          <p class="text-sm font-medium text-ijam-text-muted mb-1">Reservados</p>
          <p class="text-3xl font-bold text-ijam-primary">{reservedLoansCount}</p>
        </div>
        <div class="w-12 h-12 bg-ijam-warning/10 text-ijam-warning rounded-xl flex items-center justify-center">
          <Bookmark className="w-6 h-6" />
        </div>
      </div>

      <!-- Stat Card 4: Vencidos -->
      <div class="bg-white border-y border-r border-[#E2E8F0] border-l-4 border-l-ijam-danger rounded-xl p-6 shadow-card flex items-center justify-between card-hover transition-base">
        <div>
          <p class="text-sm font-medium text-ijam-text-muted mb-1">Vencidos</p>
          <p class="text-3xl font-bold text-ijam-primary">{overdueLoansCount}</p>
        </div>
        <div class="w-12 h-12 bg-ijam-danger/10 text-ijam-danger rounded-xl flex items-center justify-center">
          <AlertTriangle className="w-6 h-6" />
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Quick Actions -->
      <div class="lg:col-span-1 border border-ijam-surface-alt bg-white rounded-xl p-6 shadow-card h-fit">
        <h3 class="text-lg font-bold text-ijam-primary mb-5 pb-3 border-b border-ijam-surface-alt flex items-center gap-2">
          <svg class="w-5 h-5 text-ijam-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          Acciones Rápidas
        </h3>
        <div class="flex flex-col gap-3">
          <a href="/admin/agregar-libro" class="w-full text-left bg-ijam-accent/10 hover:bg-ijam-accent/15 text-ijam-accent font-semibold py-3 px-4 rounded-lg transition-colors flex items-center gap-3 border border-ijam-accent/10 hover:border-ijam-accent/25">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
            Registrar Nueva Obra
          </a>
          <button disabled class="w-full text-left bg-ijam-surface text-ijam-text-muted font-semibold py-3 px-4 rounded-lg border border-transparent cursor-not-allowed flex items-center gap-3">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            Reporte Mensual (Pronto)
          </button>
        </div>
      </div>

      <!-- Recent Activity -->
      <div class="lg:col-span-2 border border-ijam-surface-alt bg-white rounded-xl shadow-card overflow-hidden">
        <div class="p-6 border-b border-ijam-surface-alt bg-ijam-surface flex justify-between items-center">
          <h3 class="text-lg font-bold text-ijam-primary flex items-center gap-2">
            <svg class="w-5 h-5 text-ijam-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Préstamos y Reservas Recientes
          </h3>
          <a href="#" class="text-sm font-semibold text-ijam-accent hover:underline">Ver Todos</a>
        </div>
        
        <div class="overflow-x-auto">
          {(!recentLoans || recentLoans.length === 0) ? (
            <div class="p-8 text-center text-ijam-text-muted">No hay movimientos recientes registrados.</div>
          ) : (
            <table class="w-full text-sm text-left">
              <thead class="text-xs text-ijam-text uppercase bg-ijam-surface border-b border-[#E2E8F0]">
                <tr>
                  <th scope="col" class="px-6 py-4 font-bold">Estudiante</th>
                  <th scope="col" class="px-6 py-4 font-bold">Obra Requerida</th>
                  <th scope="col" class="px-6 py-4 font-bold text-center">Estado</th>
                  <th scope="col" class="px-6 py-4 font-bold text-center">Acción</th>
                </tr>
              </thead>
              <tbody>
                {recentLoans.map((loan) => {
                  const u = Array.isArray(loan.users) ? loan.users[0] : loan.users;
                  const b = Array.isArray(loan.books) ? loan.books[0] : loan.books;
                  return (
                  <tr class="bg-white border-b border-[#E2E8F0] hover:bg-ijam-surface transition-colors group">
                    <td class="px-6 py-4">
                      <p class="font-bold text-ijam-primary">{u?.full_name}</p>
                      <p class="text-xs text-ijam-text-muted">{u?.institutional_email}</p>
                    </td>
                    <td class="px-6 py-4">
                      <p class="font-medium text-ijam-text line-clamp-1">{b?.title}</p>
                      <p class="text-xs text-ijam-text-muted mt-0.5">{b?.type === 'VIRTUAL' ? 'Virtual (E-Book)' : 'Físico'}</p>
                    </td>
                    <td class="px-6 py-4 text-center">
                      {loan.status === 'ACTIVE' ? (
                         <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-ijam-accent/10 text-ijam-accent border border-ijam-accent/20">
                           <span class="w-1.5 h-1.5 rounded-full bg-ijam-accent"></span> Activo
                         </span>
                      ) : loan.status === 'OVERDUE' ? (
                         <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-red-50 text-red-600 border border-red-100">
                           <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span> Vencido
                         </span>
                      ) : (
                         <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700 border border-amber-100">
                           <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> Reserva
                         </span>
                      )}
                    </td>
                    <td class="px-6 py-4 text-center">
                      {(loan.status === 'ACTIVE' || loan.status === 'OVERDUE') ? (
                        <button
                          class="btn-return text-white bg-ijam-accent hover:brightness-110 font-semibold text-xs px-3 py-1.5 rounded-lg transition-colors"
                          data-loan-id={loan.id}
                        >
                          Devolver
                        </button>
                      ) : (
                        <span class="text-ijam-surface-alt">—</span>
                      )}
                    </td>
                  </tr>
                )})}
              </tbody>
            </table>
          )}
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.btn-return').forEach((el) => {
      const btn = el as HTMLButtonElement;
      btn.addEventListener('click', async () => {
        const loanId = btn.getAttribute('data-loan-id');
        if (!loanId) return;

        const confirmed = confirm('¿Estás seguro de marcar este préstamo como devuelto?');
        if (!confirmed) return;

        btn.disabled = true;
        btn.textContent = 'Procesando...';

        try {
          const res = await fetch('/api/admin/loans/return', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ loan_id: loanId })
          });

          const data = await res.json();

          if (res.ok && data.success) {
            location.reload();
          } else {
            alert(data.error || 'Ocurrió un error al procesar la devolución');
            btn.disabled = false;
            btn.textContent = 'Devolver';
          }
        } catch (err) {
          alert('Error de conexión. Inténtalo de nuevo.');
          btn.disabled = false;
          btn.textContent = 'Devolver';
        }
      });
    });
  });
</script>
