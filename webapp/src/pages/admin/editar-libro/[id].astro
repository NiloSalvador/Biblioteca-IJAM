---
import Layout from '../../../layouts/Layout.astro';
import { supabaseServer } from '../../../lib/supabaseServer';

const { id } = Astro.params;
const supabase = supabaseServer(Astro.cookies, Astro.request);

// 1. Validar Sesión y Rol de Admin
const { data: { session } } = await supabase.auth.getSession();
if (!session) {
  return Astro.redirect('/login');
}

const { data: profile } = await supabase.from('users').select('role').eq('id', session.user.id).single();
if (profile?.role !== 'ADMIN') {
  return Astro.redirect('/catalogo');
}

// 2. Traer info del libro a editar
const { data: book, error } = await supabase
  .from('books')
  .select('*')
  .eq('id', id)
  .single();

if (error || !book) {
  return Astro.redirect('/admin/libros');
}
---

<Layout title="Editar Libro">
  <div class="mb-10 max-w-3xl mx-auto animate-fade-in">
    <div class="flex items-center gap-4 mb-4">
      <a href="/admin/libros" class="flex items-center justify-center w-10 h-10 rounded-full bg-ijam-surface hover:bg-ijam-surface-alt text-ijam-text-muted transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
      </a>
      <div>
        <h1 class="text-3xl font-bold text-ijam-primary flex items-center gap-3">
          <svg class="w-8 h-8 text-ijam-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
          Editar Obra
        </h1>
        <p class="text-ijam-text-muted font-medium mt-0.5">Modificando la información de "{book.title}".</p>
      </div>
    </div>
    
    <div class="bg-white border border-[#E2E8F0] rounded-xl shadow-card p-8 mt-8">
      <form action="/api/admin/books/update" method="POST" enctype="multipart/form-data" class="space-y-8">
        <!-- Input ID oculto -->
        <input type="hidden" name="id" value={book.id} />
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="md:col-span-2">
            <label class="block text-sm font-bold text-ijam-text mb-2 uppercase tracking-wide">Título del Libro *</label>
            <input required type="text" name="title" value={book.title} class="w-full px-4 py-3 bg-ijam-surface border border-ijam-surface-alt rounded-lg focus:ring-2 focus:ring-ijam-accent/50 focus:border-ijam-accent transition-colors text-ijam-text" />
          </div>

          <div>
            <label class="block text-sm font-bold text-ijam-text mb-2 uppercase tracking-wide">Autor *</label>
            <input required type="text" name="author" value={book.author} class="w-full px-4 py-3 bg-ijam-surface border border-ijam-surface-alt rounded-lg focus:ring-2 focus:ring-ijam-accent/50 focus:border-ijam-accent transition-colors text-ijam-text" />
          </div>

          <div>
            <label class="block text-sm font-bold text-ijam-text mb-2 uppercase tracking-wide">Categoría</label>
            <input type="text" name="category" value={book.category || ''} class="w-full px-4 py-3 bg-ijam-surface border border-ijam-surface-alt rounded-lg focus:ring-2 focus:ring-ijam-accent/50 focus:border-ijam-accent transition-colors text-ijam-text" />
          </div>

          <div class="md:col-span-2">
            <label class="block text-sm font-bold text-ijam-text mb-2 uppercase tracking-wide">Sinopsis o Descripción</label>
            <textarea name="description" rows="4" class="w-full px-4 py-3 bg-ijam-surface border border-ijam-surface-alt rounded-lg focus:ring-2 focus:ring-ijam-accent/50 focus:border-ijam-accent resize-none text-ijam-text">{book.description || ''}</textarea>
          </div>

          <div>
            <label class="block text-sm font-bold text-ijam-text mb-2 uppercase tracking-wide">Formato *</label>
            <select name="type" required class="w-full px-4 py-3 bg-ijam-surface border border-ijam-surface-alt rounded-lg focus:ring-2 focus:ring-ijam-accent/50 focus:border-ijam-accent text-ijam-text">
              <option value="VIRTUAL" selected={book.type === 'VIRTUAL'}>Virtual (E-Book / PDF)</option>
              <option value="PHYSICAL" selected={book.type === 'PHYSICAL'}>Físico (Presencial)</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-bold text-ijam-text mb-2 uppercase tracking-wide">Stock / Copias Disponibles</label>
            <input type="number" name="stock" value={book.available_stock} class="w-full px-4 py-3 bg-ijam-surface border border-ijam-surface-alt rounded-lg focus:ring-2 focus:ring-ijam-accent/50 focus:border-ijam-accent text-ijam-text" min="0" />
          </div>

          <!-- File Uploads -->
          <div class="md:col-span-2 border-t border-[#E2E8F0] pt-6 mt-2">
            <h4 class="text-base font-bold text-ijam-primary mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-ijam-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" /></svg>
              Archivos (Dejar en blanco para mantener el actual)
            </h4>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="border-2 border-dashed border-[#E2E8F0] rounded-xl p-6 bg-ijam-surface/50 hover:bg-ijam-surface transition-colors text-center relative group">
                <input type="file" name="cover" accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
                <svg class="w-8 h-8 text-ijam-text-muted mx-auto mb-2 group-hover:text-ijam-info transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                <div class="text-sm font-semibold text-ijam-text">Cambiar Portada</div>
                {book.cover_url && <div class="text-xs text-ijam-success mt-1">Ya cuenta con una portada.</div>}
              </div>

              <div class="border-2 border-dashed border-[#E2E8F0] rounded-xl p-6 bg-ijam-surface/50 hover:bg-ijam-surface transition-colors text-center relative group">
                <input type="file" name="pdfFile" accept="application/pdf" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
                <svg class="w-8 h-8 text-ijam-text-muted mx-auto mb-2 group-hover:text-ijam-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                <div class="text-sm font-semibold text-ijam-text">Cambiar Documento PDF</div>
                 {book.resource_url && <div class="text-xs text-ijam-success mt-1">Ya cuenta con un archivo subido.</div>}
              </div>
            </div>
          </div>
        </div>

        <div class="border-t border-[#E2E8F0] pt-6 mt-8 flex justify-end gap-3">
          <a href="/admin/libros" class="px-6 py-3 border border-[#E2E8F0] rounded-lg text-ijam-text font-bold hover:bg-ijam-surface transition-colors shadow-sm">Cancelar</a>
          <button type="submit" class="px-8 py-3 bg-ijam-primary hover:bg-ijam-primary-deep text-white font-bold rounded-lg shadow-md transition-colors">
            Guardar Cambios
          </button>
        </div>

      </form>
    </div>
  </div>
</Layout>
