---
import Layout from '../../layouts/Layout.astro';
import { supabaseServer } from '../../lib/supabaseServer';
import { Book, FileText, Library, AlertCircle, Pencil, Trash2, Plus } from 'lucide-react';

const supabase = supabaseServer(Astro.cookies, Astro.request);

// 1. Validar Sesión y Rol de Admin
const { data: { session } } = await supabase.auth.getSession();
if (!session) {
  return Astro.redirect('/login');
}

const { data: profile } = await supabase.from('users').select('role').eq('id', session.user.id).single();
if (profile?.role !== 'ADMIN') {
  return Astro.redirect('/catalogo');
}

// 2. Traer Libros
const { data: books, error } = await supabase
  .from('books')
  .select('*')
  .order('created_at', { ascending: false });

const allBooks = books || [];

// Calcular contadores
const totalBooks = allBooks.length;
const virtualCount = allBooks.filter(b => b.type === 'VIRTUAL').length;
const physicalCount = allBooks.filter(b => b.type === 'PHYSICAL').length;
const outOfStockCount = allBooks.filter(b => b.available_stock === 0).length;

const DEFAULT_COVER = "https://images.unsplash.com/photo-1544947950-fa07a98d237f?q=80&w=800&auto=format&fit=crop";
---

<Layout title="Gestión de Libros | Admin">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20 animate-fade-in">
    <!-- Encabezado -->
    <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-ijam-surface-alt pb-6">
      <div>
        <div class="flex items-center gap-3 mb-3">
          <span class="bg-ijam-accent/15 text-ijam-accent text-xs font-bold px-3 py-1.5 rounded-full tracking-widest uppercase border border-ijam-accent/25">
            Administración
          </span>
        </div>
        <h1 class="text-3xl font-bold text-ijam-primary flex items-center gap-3">
          <Book className="w-8 h-8 text-ijam-accent" />
          Acervo Bibliográfico
        </h1>
        <p class="text-ijam-text-muted font-medium mt-2">Inventario de obras literarias y recursos en el sistema.</p>
      </div>
      <div>
        <a href="/admin/agregar-libro" class="flex items-center gap-2 bg-ijam-accent hover:brightness-110 text-ijam-primary font-bold py-2.5 px-5 rounded-lg transition-all shadow-md shadow-ijam-accent/20 hover:shadow-lg hover:-translate-y-0.5">
          <Plus className="w-5 h-5" />
          Agregar Libro
        </a>
      </div>
    </div>

    <!-- Contadores -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8 animate-stagger">
      <div class="bg-white border-y border-r border-[#E2E8F0] border-l-4 border-l-ijam-primary rounded-xl p-6 shadow-card flex items-center justify-between card-hover transition-base">
        <div>
          <p class="text-sm font-medium text-ijam-text-muted mb-1">Total Obras</p>
          <p class="text-3xl font-bold text-ijam-primary">{totalBooks}</p>
        </div>
        <div class="w-12 h-12 bg-ijam-surface text-ijam-primary rounded-xl flex items-center justify-center">
          <Book className="w-6 h-6" />
        </div>
      </div>
      
      <div class="bg-white border-y border-r border-[#E2E8F0] border-l-4 border-l-ijam-accent rounded-xl p-6 shadow-card flex items-center justify-between card-hover transition-base">
        <div>
          <p class="text-sm font-medium text-ijam-text-muted mb-1">Virtuales (PDF)</p>
          <p class="text-3xl font-bold text-ijam-primary">{virtualCount}</p>
        </div>
        <div class="w-12 h-12 bg-ijam-accent/10 text-ijam-accent rounded-xl flex items-center justify-center">
          <FileText className="w-6 h-6" />
        </div>
      </div>

      <div class="bg-white border-y border-r border-[#E2E8F0] border-l-4 border-l-ijam-info rounded-xl p-6 shadow-card flex items-center justify-between card-hover transition-base">
        <div>
          <p class="text-sm font-medium text-ijam-text-muted mb-1">Físicos</p>
          <p class="text-3xl font-bold text-ijam-primary">{physicalCount}</p>
        </div>
        <div class="w-12 h-12 bg-ijam-info/10 text-ijam-info rounded-xl flex items-center justify-center">
          <Library className="w-6 h-6" />
        </div>
      </div>

      <div class="bg-white border-y border-r border-[#E2E8F0] border-l-4 border-l-ijam-danger rounded-xl p-6 shadow-card flex items-center justify-between card-hover transition-base">
        <div>
          <p class="text-sm font-medium text-ijam-text-muted mb-1">Sin Stock</p>
          <p class="text-3xl font-bold text-ijam-primary">{outOfStockCount}</p>
        </div>
        <div class="w-12 h-12 bg-ijam-danger/10 text-ijam-danger rounded-xl flex items-center justify-center">
          <AlertCircle className="w-6 h-6" />
        </div>
      </div>
    </div>

    <!-- Filtros y Búsqueda -->
    <div class="bg-white border border-[#E2E8F0] rounded-xl p-4 shadow-sm mb-6 flex flex-col md:flex-row gap-4 justify-between items-center">
      <div class="relative w-full md:w-96">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
           <svg class="h-5 w-5 text-ijam-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        </div>
        <input 
          type="text" 
          id="searchInput" 
          placeholder="Buscar por título o autor..." 
          class="block w-full pl-10 pr-4 py-2 bg-ijam-surface border border-ijam-surface-alt rounded-lg focus:ring-2 focus:ring-ijam-accent/50 focus:border-ijam-accent transition-all text-sm text-ijam-text"
        />
      </div>

      <div class="flex flex-wrap gap-2 w-full md:w-auto" id="typeFilters">
        <button class="filter-btn active px-4 py-2 text-sm font-semibold rounded-lg bg-ijam-primary text-white transition-colors" data-type="ALL">Todos</button>
        <button class="filter-btn px-4 py-2 text-sm font-semibold rounded-lg bg-ijam-surface text-ijam-text-muted hover:bg-ijam-surface-alt transition-colors" data-type="VIRTUAL">Virtuales</button>
        <button class="filter-btn px-4 py-2 text-sm font-semibold rounded-lg bg-ijam-surface text-ijam-text-muted hover:bg-ijam-surface-alt transition-colors" data-type="PHYSICAL">Físicos</button>
      </div>
    </div>

    <!-- Tabla de Libros -->
    <div class="bg-white border border-[#E2E8F0] rounded-xl shadow-card overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead class="text-xs text-ijam-text uppercase bg-[#F1F5F9] border-b border-[#E2E8F0]">
            <tr>
              <th scope="col" class="px-6 py-4 font-bold">Obra</th>
              <th scope="col" class="px-6 py-4 font-bold">Autor</th>
              <th scope="col" class="px-6 py-4 font-bold">Categoría</th>
              <th scope="col" class="px-6 py-4 font-bold text-center">Tipo</th>
              <th scope="col" class="px-6 py-4 font-bold text-center">Stock Disp.</th>
              <th scope="col" class="px-6 py-4 font-bold text-center">Acciones</th>
            </tr>
          </thead>
          <tbody id="booksTableBody">
            {allBooks.map((book) => (
              <tr class="book-row bg-white border-b border-[#E2E8F0] hover:bg-[#F1F5F9] transition-colors" data-type={book.type} data-title={book.title.toLowerCase()} data-author={book.author.toLowerCase()}>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-4">
                    <img 
                      src={book.cover_url || DEFAULT_COVER} 
                      alt={`Portada ${book.title}`}
                      class="w-12 h-16 object-cover rounded shadow-sm border border-ijam-surface-alt shrink-0"
                    />
                    <span class="font-bold text-ijam-primary line-clamp-2 max-w-[200px]">{book.title}</span>
                  </div>
                </td>
                <td class="px-6 py-4 text-ijam-text">
                  <span class="font-medium line-clamp-1">{book.author}</span>
                </td>
                <td class="px-6 py-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-ijam-surface text-ijam-text-muted border border-ijam-surface-alt truncate max-w-[150px]">
                     {book.category || 'Sin categoría'}
                  </span>
                </td>
                <td class="px-6 py-4 text-center">
                  {book.type === 'VIRTUAL' ? (
                     <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-[#02f1e4]/10 text-ijam-primary border border-ijam-accent/30 tracking-wide">
                       VIRTUAL
                     </span>
                  ) : (
                     <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-[#3B82F6]/10 text-[#3B82F6] border border-[#3B82F6]/20 tracking-wide">
                       FÍSICO
                     </span>
                  )}
                </td>
                <td class="px-6 py-4 text-center">
                  <div class="flex flex-col items-center">
                    <span class={`text-lg font-bold ${book.available_stock > 0 ? 'text-ijam-success' : 'text-ijam-danger'}`}>
                      {book.available_stock}
                    </span>
                  </div>
                </td>
                <td class="px-6 py-4 text-center">
                  <div class="flex items-center justify-center gap-3">
                    <a href={`/admin/editar-libro/${book.id}`} title="Editar libro" class="p-2 text-ijam-text-muted hover:text-ijam-primary hover:bg-ijam-surface-alt rounded-lg transition-colors">
                      <Pencil className="w-4 h-4" />
                    </a>
                    <button type="button" class="btn-delete p-2 text-ijam-text-muted hover:text-ijam-danger hover:bg-red-50 rounded-lg transition-colors" data-book-id={book.id} data-book-title={book.title} title="Eliminar libro">
                      <Trash2 className="w-4 h-4" />
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
        
        {allBooks.length === 0 && (
          <div class="p-12 text-center text-ijam-text-muted flex flex-col items-center justify-center">
            <Book className="w-12 h-12 text-ijam-surface-alt mb-3" />
            <p>No se encontraron obras en el catálogo.</p>
          </div>
        )}
        
        <div id="noResults" class="p-12 text-center text-ijam-text-muted flex-col items-center justify-center hidden">
          <svg class="w-12 h-12 text-ijam-surface-alt mb-3 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <p>No hay resultados que coincidan con tu búsqueda.</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Filtrado
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const filterBtns = document.querySelectorAll('.filter-btn');
    const rows = document.querySelectorAll('.book-row');
    const noResults = document.getElementById('noResults');
    let currentType = 'ALL';

    function filterTable() {
      const searchTerm = (searchInput?.value || '').toLowerCase();
      let visibleCount = 0;

      rows.forEach((row) => {
        const r = row as HTMLElement;
        const type = r.getAttribute('data-type');
        const title = r.getAttribute('data-title') || '';
        const author = r.getAttribute('data-author') || '';

        const matchesType = currentType === 'ALL' || type === currentType;
        const matchesSearch = title.includes(searchTerm) || author.includes(searchTerm);

        if (matchesType && matchesSearch) {
          r.style.display = '';
          visibleCount++;
        } else {
          r.style.display = 'none';
        }
      });

      if (noResults) {
        if (visibleCount === 0 && rows.length > 0) {
          noResults.classList.remove('hidden');
          noResults.classList.add('flex');
        } else {
          noResults.classList.add('hidden');
          noResults.classList.remove('flex');
        }
      }
    }

    searchInput?.addEventListener('input', filterTable);

    filterBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        filterBtns.forEach(b => {
          b.classList.remove('bg-ijam-primary', 'text-white');
          b.classList.add('bg-ijam-surface', 'text-ijam-text-muted');
        });

        const target = e.currentTarget as HTMLElement;
        target.classList.remove('bg-ijam-surface', 'text-ijam-text-muted');
        target.classList.add('bg-ijam-primary', 'text-white');

        currentType = target.getAttribute('data-type') || 'ALL';
        filterTable();
      });
    });

    // Eliminación
    document.querySelectorAll('.btn-delete').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const bookId = btn.getAttribute('data-book-id');
        const bookTitle = btn.getAttribute('data-book-title');
        
        if (!bookId) return;

        if (!confirm(`¿Estás seguro de que deseas eliminar permanentemente el libro "${bookTitle}"?\nEsta acción no se puede deshacer.`)) {
          return;
        }

        const btnEl = btn as HTMLButtonElement;
        const originalContent = btnEl.innerHTML;
        btnEl.disabled = true;
        btnEl.innerHTML = '<span class="w-4 h-4 border-2 border-ijam-danger border-t-transparent rounded-full animate-spin"></span>';

        try {
          const res = await fetch('/api/admin/books/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ book_id: bookId })
          });

          const data = await res.json();

          if (res.ok && data.success) {
            // Eliminar fila de la UI
            const row = btnEl.closest('.book-row');
            if (row) {
                row.remove();
            }
            // Podríamos actualizar contadores, pero recargar la página es más seguro y sencillo
            location.reload();
          } else {
            alert(data.error || 'No se pudo eliminar el libro.');
            btnEl.disabled = false;
            btnEl.innerHTML = originalContent;
          }
        } catch (err) {
          alert('Error de conexión al intentar eliminar el libro.');
          btnEl.disabled = false;
          btnEl.innerHTML = originalContent;
        }
      });
    });
  });
</script>
