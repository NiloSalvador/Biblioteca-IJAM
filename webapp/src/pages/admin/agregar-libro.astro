---
import Layout from '../../layouts/Layout.astro';
import { supabaseServer } from '../../lib/supabaseServer';

const supabase = supabaseServer(Astro.cookies, Astro.request);

// 1. Validar Sesión y Rol de Admin
const { data: { session } } = await supabase.auth.getSession();
if (!session) {
  return Astro.redirect('/login');
}

const { data: profile } = await supabase.from('users').select('role').eq('id', session.user.id).single();
if (profile?.role !== 'ADMIN') {
  return Astro.redirect('/catalogo');
}

---

<Layout title="Agregar Nuevo Libro">
  <div class="mb-10 max-w-3xl mx-auto">
    <div class="flex items-center gap-4 mb-4">
      <a href="/admin/dashboard" class="flex items-center justify-center w-10 h-10 rounded-full bg-slate-100 hover:bg-slate-200 text-slate-600 transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
      </a>
      <div>
        <h1 class="text-3xl font-bold text-blue-950">Añadir Nueva Obra</h1>
        <p class="text-slate-500 font-medium mt-0.5">Ingrese los detalles para registrar un nuevo libro al catálogo.</p>
      </div>
    </div>

    <!-- We use normal form submission to API route, but you could do client:load if you wanted to upload files directly easily. For now, since storage requires signed or secure POST, you can do it via API Route or a React component. We'll simulate a standard HTML form that a backend endpoint handles so Astro stays clean -->
    
    <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-8 mt-8">
      <form action="/api/admin/books/create" method="POST" enctype="multipart/form-data" class="space-y-8">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="md:col-span-2">
            <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wide">Título del Libro *</label>
            <input required type="text" name="title" class="w-full px-4 py-3 bg-slate-50 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600 transition-colors" placeholder="Ej. Principios de la Teología" />
          </div>

          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wide">Autor *</label>
            <input required type="text" name="author" class="w-full px-4 py-3 bg-slate-50 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600 transition-colors" placeholder="Nombre del autor" />
          </div>

          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wide">Categoría</label>
            <input type="text" name="category" class="w-full px-4 py-3 bg-slate-50 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" placeholder="Ej. Historia de la Iglesia" />
          </div>

          <div class="md:col-span-2">
            <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wide">Sinopsis o Descripción</label>
            <textarea name="description" rows="4" class="w-full px-4 py-3 bg-slate-50 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600 resize-none" placeholder="Breve resumen del contenido..." />
          </div>

          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wide">Formato *</label>
            <select name="type" required class="w-full px-4 py-3 bg-slate-50 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600">
              <option value="VIRTUAL">Virtual (E-Book / PDF)</option>
              <option value="PHYSICAL">Físico (Presencial)</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wide">Stock / Copias Disponibles</label>
            <input type="number" name="stock" class="w-full px-4 py-3 bg-slate-50 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-blue-600" value="1" min="1" />
          </div>

          <!-- File Uploads -->
          <div class="md:col-span-2 border-t border-slate-200 pt-6 mt-2">
            <h4 class="text-base font-bold text-blue-950 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-cyan-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" /></svg>
              Archivos del Recurso
            </h4>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="border-2 border-dashed border-slate-300 rounded-xl p-6 bg-slate-50/50 hover:bg-slate-50 transition-colors text-center relative group">
                <input type="file" name="cover" accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
                <svg class="w-8 h-8 text-slate-400 mx-auto mb-2 group-hover:text-blue-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                <div class="text-sm font-semibold text-slate-700">Subir Portada (JPG/PNG)</div>
                <div class="text-xs text-slate-500 mt-1">Opcional pero recomendado</div>
              </div>

              <div class="border-2 border-dashed border-slate-300 rounded-xl p-6 bg-slate-50/50 hover:bg-slate-50 transition-colors text-center relative group">
                <input type="file" name="pdfFile" accept="application/pdf" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
                <svg class="w-8 h-8 text-slate-400 mx-auto mb-2 group-hover:text-cyan-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                <div class="text-sm font-semibold text-slate-700">Subir Documento (PDF)</div>
                <div class="text-xs text-slate-500 mt-1">Solo requerido para libros Virtuales</div>
              </div>
            </div>
          </div>
        </div>

        <div class="border-t border-slate-200 pt-6 mt-8 flex justify-end gap-3">
          <a href="/admin/dashboard" class="px-6 py-3 border border-slate-300 rounded-lg text-slate-700 font-bold hover:bg-slate-50 transition-colors">Cancelar</a>
          <button type="submit" class="px-8 py-3 bg-cyan-600 hover:bg-cyan-700 text-white font-bold rounded-lg shadow-sm transition-colors">
            Guardar Libro en Catálogo
          </button>
        </div>

      </form>
    </div>
  </div>
</Layout>
