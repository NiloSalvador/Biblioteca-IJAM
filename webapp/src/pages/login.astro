---
import Layout from '../layouts/Layout.astro';

const { url } = Astro;
const errorMsg = url.searchParams.get('error');
const successMsg = url.searchParams.get('msg');
// Validar si ya está logueado para redirigir
import { supabaseServer } from '../lib/supabaseServer';
const supabase = supabaseServer(Astro.cookies, Astro.request);
const { data: { session } } = await supabase.auth.getSession();

if (session) {
  return Astro.redirect('/catalogo');
}
---

<Layout title="Iniciar Sesión">
  <!-- Full-screen login con gradiente primary como fondo -->
  <section class="min-h-screen flex items-center justify-center relative overflow-hidden">
    <!-- BG -->
    <div class="absolute inset-0 gradient-primary"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.4) 1px, transparent 1px); background-size: 28px 28px;"></div>
    <div class="absolute top-1/3 right-1/4 w-[400px] h-[400px] bg-ijam-accent/5 rounded-full blur-[100px]"></div>

    <!-- Login Card -->
    <div class="relative z-10 w-full max-w-[480px] mx-4 animate-fade-in">
      <div class="bg-white rounded-[var(--radius-xl)] shadow-card p-8 sm:p-10">
        
        <!-- Logo area -->
        <div class="text-center mb-8">
          <div class="w-14 h-14 bg-ijam-accent rounded-xl flex items-center justify-center mx-auto mb-5 shadow-md shadow-ijam-accent/20">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
          </div>
          <h1 class="text-2xl font-bold text-ijam-text mb-1">Iniciar Sesión</h1>
          <p class="text-ijam-text-muted text-sm">Portal para estudiantes y docentes</p>
        </div>

        <!-- Success msg -->
        {successMsg && (
          <div class="bg-emerald-50 border border-emerald-200 text-ijam-success p-3.5 mb-6 text-[0.8rem] flex gap-2 items-center rounded-[var(--radius-md)]">
            <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            {successMsg}
          </div>
        )}

        <!-- Error msg -->
        {errorMsg && (
          <div class="bg-red-50 border border-red-200 text-[#EF4444] p-3.5 mb-6 text-[0.8rem] flex gap-2 items-center rounded-[var(--radius-md)]">
            <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
            {errorMsg}
          </div>
        )}

        <!-- Form -->
        <form action="/api/auth/signin" method="POST" class="space-y-5">
          <div>
            <label for="email" class="block text-[0.875rem] font-medium text-[#1E293B] mb-1.5">Correo Institucional</label>
            <input 
              type="email" 
              name="email" 
              id="email" 
              placeholder="ejemplo@ijamvirtual.edu.pe"
              class="block w-full px-4 py-3 bg-white border border-[#E2E8F0] rounded-[var(--radius-md)] focus:ring-2 focus:ring-ijam-accent/30 focus:border-ijam-accent transition-all text-ijam-text text-sm"
              required 
            />
          </div>

          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label for="password" class="block text-[0.875rem] font-medium text-[#1E293B]">Contraseña</label>
              <a href="#" class="text-xs text-ijam-accent hover:brightness-110 hover:underline font-medium">¿Olvidó su contraseña?</a>
            </div>
            <input 
              type="password" 
              name="password" 
              id="password" 
              placeholder="••••••••"
              class="block w-full px-4 py-3 bg-white border border-[#E2E8F0] rounded-[var(--radius-md)] focus:ring-2 focus:ring-ijam-accent/30 focus:border-ijam-accent transition-all text-ijam-text text-sm"
              required 
            />
          </div>

          <button 
            type="submit" 
            class="w-full flex justify-center py-3.5 px-4 text-sm font-bold text-ijam-primary bg-ijam-accent hover:brightness-110 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-ijam-accent rounded-[var(--radius-md)] transition-all duration-200 mt-3 shadow-md shadow-ijam-accent/20 hover:shadow-lg hover:shadow-ijam-accent/30 hover:-translate-y-0.5"
          >
            Acceder al Sistema
          </button>
        </form>

        <!-- Bottom link -->
        <p class="text-center text-ijam-text-muted text-sm mt-6">
          ¿No tienes cuenta?
          <a href="/registro" class="font-semibold text-ijam-accent hover:brightness-110 hover:underline ml-1">Regístrate</a>
        </p>
      </div>
    </div>
  </section>
</Layout>
