---
import { supabaseServer } from '../lib/supabaseServer';

const supabase = supabaseServer(Astro.cookies, Astro.request);
const { data: { session } } = await supabase.auth.getSession();

let userRole = 'GUEST';
let userFullName = '';
let initials = '';

if (session?.user) {
  const { data: profile } = await supabase.from('users').select('role, full_name').eq('id', session.user.id).single();
  userRole = profile?.role || 'STUDENT';
  userFullName = profile?.full_name || 'Usuario';
  
  const parts = userFullName.trim().split(' ');
  initials = parts.length >= 2 
    ? `${parts[0][0]}${parts[1][0]}`.toUpperCase() 
    : userFullName.substring(0, 2).toUpperCase();
}

const currentPath = Astro.url.pathname;
---

<!-- Navbar — DESIGN_SYSTEM.md Sección 6.1 -->
<header class="sticky top-0 w-full z-50 gradient-primary shadow-navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-14 md:h-16 flex items-center justify-between">
    
    <!-- Logo & Brand -->
    <a href="/" class="flex items-center gap-3 group shrink-0">
      <div class="w-10 h-10 bg-ijam-accent rounded-lg flex items-center justify-center shadow-md shadow-ijam-accent/20 group-hover:shadow-lg group-hover:shadow-ijam-accent/30 transition-all duration-200">
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
      </div>
      <span class="text-lg font-bold tracking-tight text-white uppercase hidden sm:block">
        Biblioteca <span class="text-ijam-accent">IJAM</span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-8 text-sm font-medium">
      <a href="/" class:list={[
        "relative py-1 transition-colors duration-200",
        currentPath === '/' ? "text-ijam-accent after:absolute after:bottom-[-4px] after:left-0 after:w-full after:h-[2px] after:bg-ijam-accent" : "text-white/70 hover:text-ijam-accent after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-ijam-accent after:transition-all hover:after:w-full"
      ]}>Inicio</a>
      <a href="/catalogo" class:list={[
        "relative py-1 transition-colors duration-200",
        currentPath === '/catalogo' ? "text-ijam-accent after:absolute after:bottom-[-4px] after:left-0 after:w-full after:h-[2px] after:bg-ijam-accent" : "text-white/70 hover:text-ijam-accent after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-ijam-accent after:transition-all hover:after:w-full"
      ]}>Catálogo</a>

      {userRole !== 'GUEST' && (
        <a href="/mis-prestamos" class:list={[
          "relative py-1 transition-colors duration-200",
          currentPath === '/mis-prestamos' ? "text-ijam-accent after:absolute after:bottom-[-4px] after:left-0 after:w-full after:h-[2px] after:bg-ijam-accent" : "text-white/70 hover:text-ijam-accent after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-ijam-accent after:transition-all hover:after:w-full"
        ]}>Mis Préstamos</a>
      )}
      {userRole === 'ADMIN' && (
        <>
          <a href="/admin/dashboard" class:list={[
            "relative py-1 transition-colors duration-200",
            currentPath === '/admin/dashboard' ? "text-ijam-accent after:absolute after:bottom-[-4px] after:left-0 after:w-full after:h-[2px] after:bg-ijam-accent" : "text-white/70 hover:text-ijam-accent after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-ijam-accent after:transition-all hover:after:w-full"
          ]}>Administración</a>
          <a href="/admin/usuarios" class:list={[
            "relative py-1 transition-colors duration-200",
            currentPath === '/admin/usuarios' ? "text-ijam-accent after:absolute after:bottom-[-4px] after:left-0 after:w-full after:h-[2px] after:bg-ijam-accent" : "text-white/70 hover:text-ijam-accent after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-ijam-accent after:transition-all hover:after:w-full"
          ]}>Usuarios</a>
          <a href="/admin/libros" class:list={[
            "relative py-1 transition-colors duration-200",
            currentPath === '/admin/libros' ? "text-ijam-accent after:absolute after:bottom-[-4px] after:left-0 after:w-full after:h-[2px] after:bg-ijam-accent" : "text-white/70 hover:text-ijam-accent after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-ijam-accent after:transition-all hover:after:w-full"
          ]}>Libros</a>
          <a href="/admin/prestamos" class:list={[
            "relative py-1 transition-colors duration-200",
            currentPath === '/admin/prestamos' ? "text-ijam-accent after:absolute after:bottom-[-4px] after:left-0 after:w-full after:h-[2px] after:bg-ijam-accent" : "text-white/70 hover:text-ijam-accent after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-[2px] after:bg-ijam-accent after:transition-all hover:after:w-full"
          ]}>Préstamos</a>
        </>
      )}
    </nav>

    <!-- Desktop Auth + Mobile Hamburger -->
    <div class="flex items-center gap-4">
      <!-- Desktop auth buttons -->
      <div class="hidden md:flex items-center gap-4">
        {userRole === 'GUEST' ? (
          <a href="/login" class="px-5 py-2 bg-ijam-accent hover:brightness-110 text-ijam-primary text-sm font-semibold transition-all duration-200 rounded-[var(--radius-md)] shadow-sm shadow-ijam-accent/20 hover:shadow-md hover:shadow-ijam-accent/30 hover:-translate-y-0.5">
            Acceder
          </a>
        ) : (
          <>
            <a href="/perfil" class="flex items-center gap-2 group px-2 py-1 rounded-full hover:bg-white/10 transition-colors">
              <div class="w-8 h-8 rounded-full gradient-primary flex items-center justify-center text-xs font-bold text-white shadow-sm border border-white/20 group-hover:border-white transition-colors">
                {initials}
              </div>
              <span class="text-sm font-medium text-white/90 group-hover:text-white transition-colors">
                {userFullName.split(' ')[0]}
              </span>
            </a>
            <form action="/api/auth/signout" method="POST">
              <button type="submit" class="p-2 text-white/70 hover:text-white hover:bg-white/10 transition-all duration-200 rounded-lg" title="Cerrar sesión">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
              </button>
            </form>
          </>
        )}
      </div>

      <!-- Mobile hamburger button -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden flex items-center justify-center w-10 h-10 text-white/80 hover:text-ijam-accent transition-colors rounded-lg hover:bg-white/10"
        aria-label="Abrir menú"
      >
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile slide-in panel -->
<div id="mobile-menu-overlay" class="fixed inset-0 z-40 bg-black/50 backdrop-blur-sm hidden md:hidden transition-opacity duration-300 opacity-0"></div>
<nav id="mobile-menu-panel" class="fixed top-0 right-0 z-50 h-full w-72 bg-[#000949]/95 backdrop-blur-md shadow-2xl transform translate-x-full transition-transform duration-300 ease-in-out md:hidden">
  <div class="flex flex-col h-full pt-20 pb-8 px-6">
    <!-- Mobile nav links -->
    <div class="flex flex-col gap-1">
      <a href="/" class:list={[
        "mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200",
        currentPath === '/' ? "bg-ijam-accent/15 text-ijam-accent" : "text-white/80 hover:bg-white/10 hover:text-ijam-accent"
      ]}>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
        Inicio
      </a>
      <a href="/catalogo" class:list={[
        "mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200",
        currentPath === '/catalogo' ? "bg-ijam-accent/15 text-ijam-accent" : "text-white/80 hover:bg-white/10 hover:text-ijam-accent"
      ]}>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
        Catálogo
      </a>
      {userRole !== 'GUEST' && (
        <a href="/mis-prestamos" class:list={[
          "mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200",
          currentPath === '/mis-prestamos' ? "bg-ijam-accent/15 text-ijam-accent" : "text-white/80 hover:bg-white/10 hover:text-ijam-accent"
        ]}>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          Mis Préstamos
        </a>
      )}
      {userRole === 'ADMIN' && (
        <>
          <a href="/admin/dashboard" class:list={[
            "mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200",
            currentPath === '/admin/dashboard' ? "bg-ijam-accent/15 text-ijam-accent" : "text-white/80 hover:bg-white/10 hover:text-ijam-accent"
          ]}>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" /></svg>
            Administración
          </a>
          <a href="/admin/usuarios" class:list={[
            "mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200",
            currentPath === '/admin/usuarios' ? "bg-ijam-accent/15 text-ijam-accent" : "text-white/80 hover:bg-white/10 hover:text-ijam-accent"
          ]}>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
            Usuarios
          </a>
          <a href="/admin/libros" class:list={[
            "mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200",
            currentPath === '/admin/libros' ? "bg-ijam-accent/15 text-ijam-accent" : "text-white/80 hover:bg-white/10 hover:text-ijam-accent"
          ]}>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
            Libros
          </a>
          <a href="/admin/prestamos" class:list={[
            "mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200",
            currentPath === '/admin/prestamos' ? "bg-ijam-accent/15 text-ijam-accent" : "text-white/80 hover:bg-white/10 hover:text-ijam-accent"
          ]}>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" /></svg>
            Préstamos
          </a>
        </>
      )}
    </div>

    <!-- Mobile auth section -->
    <div class="mt-auto border-t border-white/10 pt-6">
      {userRole === 'GUEST' ? (
        <a href="/login" class="mobile-nav-link w-full flex justify-center items-center gap-2 px-5 py-3 bg-ijam-accent text-ijam-primary text-sm font-bold rounded-lg transition-all duration-200 hover:brightness-110">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" /></svg>
          Acceder al Sistema
        </a>
      ) : (
        <div class="space-y-4">
          <a href="/perfil" class="mobile-nav-link w-full flex items-center gap-3 px-4 py-3 bg-white/5 hover:bg-white/10 rounded-lg transition-colors">
            <div class="w-10 h-10 rounded-full gradient-primary flex items-center justify-center text-sm font-bold text-white shadow-sm border border-white/20">
              {initials}
            </div>
            <div class="flex flex-col">
              <span class="text-sm font-bold text-white">{userFullName}</span>
              <span class="text-xs text-ijam-accent">Ver mi perfil</span>
            </div>
          </a>
          <form action="/api/auth/signout" method="POST">
            <button type="submit" class="mobile-nav-link w-full flex justify-center items-center gap-2 px-5 py-2.5 border border-white/20 text-white/80 text-sm font-medium hover:bg-white/10 hover:border-white/40 transition-all duration-200 rounded-lg">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
              Cerrar Sesión
            </button>
          </form>
        </div>
      )}
    </div>
  </div>
</nav>

<!-- Mobile menu JavaScript -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const overlay = document.getElementById('mobile-menu-overlay');
    const panel = document.getElementById('mobile-menu-panel');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');
    const mobileLinks = document.querySelectorAll('.mobile-nav-link');

    let isOpen = false;

    function openMenu() {
      isOpen = true;
      overlay?.classList.remove('hidden');
      requestAnimationFrame(() => {
        overlay?.classList.remove('opacity-0');
        overlay?.classList.add('opacity-100');
      });
      panel?.classList.remove('translate-x-full');
      panel?.classList.add('translate-x-0');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      isOpen = false;
      overlay?.classList.remove('opacity-100');
      overlay?.classList.add('opacity-0');
      panel?.classList.remove('translate-x-0');
      panel?.classList.add('translate-x-full');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      document.body.style.overflow = '';
      setTimeout(() => {
        overlay?.classList.add('hidden');
      }, 300);
    }

    btn?.addEventListener('click', () => isOpen ? closeMenu() : openMenu());
    overlay?.addEventListener('click', closeMenu);
    mobileLinks.forEach(link => link.addEventListener('click', closeMenu));
  });
</script>
