// Footer — DESIGN_SYSTEM.md Sección 6.7
---

<footer class="bg-ijam-primary">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">
      
      <!-- Logo & Description -->
      <div class="md:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-ijam-accent rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
          </div>
          <span class="text-white font-bold text-lg tracking-tight">Biblioteca <span class="text-ijam-accent">IJAM</span></span>
        </div>
        <p class="text-white/70 text-sm leading-relaxed max-w-xs">
          Instituto de Educación Superior Tecnológico Privado "John A. Mackay"
        </p>
      </div>

      <!-- Enlaces rápidos -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Enlaces rápidos</h4>
        <ul class="space-y-3">
          <li><a href="/catalogo" class="text-white/70 hover:text-ijam-accent transition-colors duration-200 text-sm">Catálogo</a></li>
          <li><a href="/mis-prestamos" class="text-white/70 hover:text-ijam-accent transition-colors duration-200 text-sm">Mis Préstamos</a></li>
          <li><a href="/login" class="text-white/70 hover:text-ijam-accent transition-colors duration-200 text-sm">Iniciar Sesión</a></li>
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Contacto</h4>
        <ul class="space-y-3 text-sm text-white/70">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-ijam-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            Jr. Bernardo Alcedo, Rioja, San Martín
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-ijam-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            (+51) 961 577 437
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider & Copyright -->
    <div class="border-t border-white/10 mt-10 pt-6 text-center">
      <p class="text-white/50 text-[0.8rem]">&copy; {new Date().getFullYear()} Instituto John A. Mackay. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
